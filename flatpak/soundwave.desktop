[Desktop Entry]
Name=Soundwave
Comment=Reproductor de música moderno para Linux
Exec=soundwave
Icon=io.github.manuelprz.Soundwave
Terminal=false
Type=Application
Categories=Audio;AudioVideo;Player;
MimeType=audio/mpeg;audio/flac;audio/ogg;audio/x-m4a;audio/wav;audio/aac;
StartupNotify=true
DBusActivatable=true
